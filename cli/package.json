{
  "name": "@midnight-pangolin/cli",
  "version": "1.0.0",
  "description": "CLI for Midnight Pangolin project",
  "type": "module",
  "license": "GPL-3.0",
  "keywords": [],
  "author": "Bett Moses Kiprono",
  "private": true,
  "scripts": {
    "build": "rm -rf dist && tsc --project tsconfig.build.json",
    "ci": "pnpm run typecheck && pnpm run lint && pnpm run build",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "pnpm run build",
    "standalone": "node --experimental-specifier-resolution=node --loader ts-node/esm src/launcher/standalone.ts",
    "preview-remote": "node --experimental-specifier-resolution=node --loader ts-node/esm src/launcher/preview.ts",
    "preprod-remote": "node --experimental-specifier-resolution=node --loader ts-node/esm src/launcher/preprod.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "engines": {
    "node": ">=24.11.1"
  },
  "devDependencies": {
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.9.5"
  },
  "dependencies": {
    "@midnight-ntwrk/wallet-sdk-address-format": "^3.1.2",
    "@midnight-ntwrk/wallet-sdk-facade": "^4.0.1",
    "@midnight-ntwrk/wallet-sdk-shielded": "^3.0.1",
    "@midnight-ntwrk/wallet-sdk-unshielded-wallet": "^3.1.0"
  }
}